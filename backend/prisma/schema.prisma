generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== MÓDULO DE SEGURIDAD ====================

model seg_usuarios {
  id                 Int                @id @default(autoincrement())
  email              String             @unique @db.VarChar(255)
  password_hash      String             @db.Text
  email_verificado   Boolean            @default(false)
  token_verificacion String?            @db.Text
  activo             Boolean            @default(true)
  fecha_ultimo_login DateTime?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  created_by         Int?
  updated_by         Int?

  // Relaciones
  usuario_roles      seg_usuario_rol[]
  refresh_tokens     seg_refresh_tokens[]
  cliente            cli_clientes?
  auditorias         auditoria_registro[]
  historial_estados  ord_historial_estados[]
  carritos           ord_carritos[]

  @@map("seg_usuarios")
}

model seg_roles {
  id              Int              @id @default(autoincrement())
  nombre          String           @unique @db.VarChar(50)
  descripcion     String?          @db.Text
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  // Relaciones
  usuario_roles   seg_usuario_rol[]
  rol_permisos    seg_rol_permiso[]

  @@map("seg_roles")
}

model seg_permisos {
  id              Int              @id @default(autoincrement())
  modulo          String           @db.VarChar(50)
  accion          String           @db.VarChar(20)
  created_at      DateTime         @default(now())

  // Relaciones
  rol_permisos    seg_rol_permiso[]

  @@unique([modulo, accion])
  @@map("seg_permisos")
}

model seg_rol_permiso {
  rol_id       Int
  permiso_id   Int
  created_at   DateTime @default(now())

  // Relaciones
  rol          seg_roles    @relation(fields: [rol_id], references: [id])
  permiso      seg_permisos @relation(fields: [permiso_id], references: [id])

  @@id([rol_id, permiso_id])
  @@map("seg_rol_permiso")
}

model seg_usuario_rol {
  usuario_id   Int
  rol_id       Int
  created_at   DateTime @default(now())

  // Relaciones
  usuario      seg_usuarios @relation(fields: [usuario_id], references: [id])
  rol          seg_roles    @relation(fields: [rol_id], references: [id])

  @@id([usuario_id, rol_id])
  @@map("seg_usuario_rol")
}

model seg_refresh_tokens {
  id           Int      @id @default(autoincrement())
  usuario_id   Int
  token        String   @db.Text
  expira_en    DateTime
  revocado     Boolean  @default(false)
  ip           String?  @db.VarChar(45)
  user_agent   String?  @db.Text
  created_at   DateTime @default(now())

  // Relaciones
  usuario      seg_usuarios @relation(fields: [usuario_id], references: [id])

  @@map("seg_refresh_tokens")
}

// ==================== MÓDULO DE CLIENTES ====================

model cli_clientes {
  id                  Int                  @id @default(autoincrement())
  usuario_id          Int                  @unique
  telefono            String?              @db.VarChar(20)
  fecha_nacimiento    DateTime?
  total_gastado       Decimal              @default(0) @db.Decimal(10, 2)
  fecha_ultima_compra DateTime?
  segmento            String               @default("nuevo") @db.VarChar(20)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  // Relaciones
  usuario              seg_usuarios                 @relation(fields: [usuario_id], references: [id])
  direcciones          cli_direcciones[]
  lista_deseos         cli_lista_deseos[]
  resenas              cli_resenas_producto[]
  ordenes              ord_ordenes[]
  historial_navegacion cli_historial_navegacion[]
  direcciones_envio    ord_direcciones_envio[]

  @@map("cli_clientes")
}

model cli_direcciones {
  id                 Int      @id @default(autoincrement())
  cliente_id         Int
  alias              String   @db.VarChar(50)
  direccion_completa String   @db.Text
  ciudad             String   @db.VarChar(100)
  departamento       String   @db.VarChar(100)
  codigo_postal      String?  @db.VarChar(20)
  telefono           String   @db.VarChar(20)
  es_principal       Boolean  @default(false)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  // Relaciones
  cliente            cli_clientes @relation(fields: [cliente_id], references: [id])

  @@map("cli_direcciones")
}

model cli_lista_deseos {
  id          Int      @id @default(autoincrement())
  cliente_id  Int
  nombre_lista String  @default("Mi lista") @db.VarChar(100)
  fecha_creacion DateTime @default(now())

  // Relaciones
  cliente      cli_clientes               @relation(fields: [cliente_id], references: [id])
  items        cli_items_lista_deseos[]

  @@map("cli_lista_deseos")
}

model cli_items_lista_deseos {
  id           Int      @id @default(autoincrement())
  lista_id     Int
  producto_id  Int
  variante_id  Int?
  fecha_agregado DateTime @default(now())

  // Relaciones
  lista        cli_lista_deseos @relation(fields: [lista_id], references: [id])
  producto     cat_productos     @relation(fields: [producto_id], references: [id])

  @@map("cli_items_lista_deseos")
}

model cli_resenas_producto {
  id           Int      @id @default(autoincrement())
  cliente_id   Int
  producto_id  Int
  orden_id     Int?
  calificacion Int
  comentario   String?  @db.Text
  fecha_resena DateTime @default(now())

  // Relaciones
  cliente      cli_clientes @relation(fields: [cliente_id], references: [id])
  producto     cat_productos @relation(fields: [producto_id], references: [id])
  orden        ord_ordenes?  @relation(fields: [orden_id], references: [id])

  @@map("cli_resenas_producto")
}

model cli_historial_navegacion {
  id           Int      @id @default(autoincrement())
  cliente_id   Int?
  session_id   String?  @db.VarChar(255)
  producto_id  Int
  fecha_visita DateTime @default(now())
  tiempo_permanencia_seg Int?

  // Relaciones
  cliente      cli_clientes? @relation(fields: [cliente_id], references: [id])
  producto     cat_productos  @relation(fields: [producto_id], references: [id])

  @@map("cli_historial_navegacion")
}

// ==================== MÓDULO DE CATÁLOGO ====================

model cat_categorias {
  id                Int                @id @default(autoincrement())
  nombre            String             @db.VarChar(100)
  slug              String             @unique @db.VarChar(100)
  descripcion       String?            @db.Text
  imagen_url        String?            @db.Text
  categoria_padre_id Int?
  activo            Boolean            @default(true)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  created_by        Int?
  updated_by        Int?

  // Relaciones
  categoria_padre   cat_categorias?    @relation("categoria_subcategoria", fields: [categoria_padre_id], references: [id])
  subcategorias     cat_categorias[]   @relation("categoria_subcategoria")
  productos         cat_productos[]
  subcategorias_child cat_subcategorias[]

  @@map("cat_categorias")
}

model cat_subcategorias {
  id            Int      @id @default(autoincrement())
  categoria_id  Int
  nombre        String   @db.VarChar(100)
  slug          String   @unique @db.VarChar(100)
  activo        Boolean  @default(true)
  created_at    DateTime @default(now())

  // Relaciones
  categoria     cat_categorias @relation(fields: [categoria_id], references: [id])
  productos     cat_productos[]

  @@map("cat_subcategorias")
}

model cat_marcas {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique @db.VarChar(100)
  logo_url    String?  @db.Text
  activo      Boolean  @default(true)
  created_at  DateTime @default(now())

  // Relaciones
  productos   cat_productos[]

  @@map("cat_marcas")
}

model cat_unidades_medida {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(50)
  abreviatura String   @db.VarChar(10)
  created_at  DateTime @default(now())

  // Relaciones
  productos   cat_productos[]

  @@map("cat_unidades_medida")
}

model cat_productos {
  id                 Int                     @id @default(autoincrement())
  sku                String                  @unique @db.VarChar(50)
  nombre             String                  @db.VarChar(255)
  descripcion_corta  String?                 @db.Text
  descripcion_larga  String?                 @db.Text
  categoria_id       Int
  subcategoria_id    Int?
  marca_id           Int?
  unidad_medida_id   Int
  precio_costo       Decimal                 @default(0) @db.Decimal(10, 2)
  precio_venta       Decimal                 @default(0) @db.Decimal(10, 2)
  precio_oferta      Decimal?                @db.Decimal(10, 2)
  fecha_inicio_oferta DateTime?
  fecha_fin_oferta   DateTime?
  peso               Decimal?                @db.Decimal(8, 2)
  ancho              Decimal?                @db.Decimal(8, 2)
  alto               Decimal?                @db.Decimal(8, 2)
  profundidad        Decimal?                @db.Decimal(8, 2)
  ventas_totales     Int                     @default(0)
  estado             String                  @default("activo") @db.VarChar(20)
  activo             Boolean                 @default(true)
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  created_by         Int?
  updated_by         Int?

  // Relaciones
  categoria          cat_categorias          @relation(fields: [categoria_id], references: [id])
  subcategoria       cat_subcategorias?      @relation(fields: [subcategoria_id], references: [id])
  marca              cat_marcas?             @relation(fields: [marca_id], references: [id])
  unidad_medida      cat_unidades_medida     @relation(fields: [unidad_medida_id], references: [id])
  imagenes           cat_imagenes_producto[]
  producto_atributos cat_producto_atributo[]
  producto_etiquetas cat_producto_etiqueta[]
  stock              inv_stock_producto?
  carrito_items      ord_items_carrito[]
  orden_items        ord_items_orden[]
  lista_deseos_items cli_items_lista_deseos[]
  resenas            cli_resenas_producto[]
  historial_navegacion cli_historial_navegacion[]
  compras_detalle    inv_detalle_orden_compra[]

  @@index([categoria_id])
  @@index([marca_id])
  @@index([nombre])
  @@map("cat_productos")
}

model cat_etiquetas {
  id                Int                  @id @default(autoincrement())
  nombre            String               @unique @db.VarChar(50)
  color             String?              @db.VarChar(7)
  created_at        DateTime             @default(now())

  // Relaciones
  producto_etiquetas cat_producto_etiqueta[]

  @@map("cat_etiquetas")
}

model cat_producto_etiqueta {
  producto_id  Int
  etiqueta_id  Int
  created_at   DateTime @default(now())

  // Relaciones
  producto     cat_productos @relation(fields: [producto_id], references: [id])
  etiqueta     cat_etiquetas @relation(fields: [etiqueta_id], references: [id])

  @@id([producto_id, etiqueta_id])
  @@map("cat_producto_etiqueta")
}

model cat_atributos {
  id          Int                     @id @default(autoincrement())
  nombre      String                  @db.VarChar(50)
  tipo        String                  @db.VarChar(20)
  created_at  DateTime                @default(now())

  // Relaciones
  valores     cat_valores_atributo[]
  producto_atributos cat_producto_atributo[]

  @@map("cat_atributos")
}

model cat_valores_atributo {
  id          Int                     @id @default(autoincrement())
  atributo_id Int
  valor       String                  @db.VarChar(100)
  created_at  DateTime                @default(now())

  // Relaciones
  atributo    cat_atributos           @relation(fields: [atributo_id], references: [id])
  producto_atributos cat_producto_atributo[]

  @@map("cat_valores_atributo")
}

model cat_producto_atributo {
  id               Int      @id @default(autoincrement())
  producto_id      Int
  atributo_id      Int
  valor_id         Int
  precio_adicional Decimal? @db.Decimal(10, 2)
  stock            Int      @default(0)
  created_at       DateTime @default(now())

  // Relaciones
  producto         cat_productos       @relation(fields: [producto_id], references: [id])
  atributo         cat_atributos       @relation(fields: [atributo_id], references: [id])
  valor            cat_valores_atributo @relation(fields: [valor_id], references: [id])

  @@map("cat_producto_atributo")
}

model cat_imagenes_producto {
  id          Int      @id @default(autoincrement())
  producto_id Int
  url         String   @db.Text
  orden       Int      @default(0)
  es_principal Boolean @default(false)
  created_at  DateTime @default(now())

  // Relaciones
  producto    cat_productos @relation(fields: [producto_id], references: [id])

  @@map("cat_imagenes_producto")
}

// ==================== MÓDULO DE INVENTARIO ====================

model inv_stock_producto {
  id               Int      @id @default(autoincrement())
  producto_id      Int      @unique
  variante_id      Int?
  stock_fisico     Int      @default(0)
  stock_reservado  Int      @default(0)
  stock_minimo     Int      @default(0)
  ubicacion_almacen String? @db.VarChar(100)
  updated_at       DateTime @updatedAt

  // Relaciones
  producto         cat_productos           @relation(fields: [producto_id], references: [id])
  movimientos      inv_movimientos_inventario[]

  @@map("inv_stock_producto")
}

model inv_movimientos_inventario {
  id               Int      @id @default(autoincrement())
  producto_id      Int
  variante_id      Int?
  tipo_movimiento  String   @db.VarChar(20)
  cantidad         Int
  stock_antes      Int
  stock_despues    Int
  motivo           String   @db.Text
  referencia_id    Int?
  fecha_movimiento DateTime @default(now())
  usuario_id       Int?

  // Relaciones
  producto         inv_stock_producto @relation(fields: [producto_id], references: [producto_id])

  @@index([producto_id])
  @@index([fecha_movimiento])
  @@map("inv_movimientos_inventario")
}

model inv_proveedores {
  id             Int      @id @default(autoincrement())
  razon_social   String   @db.VarChar(200)
  ruc            String   @unique @db.VarChar(20)
  email          String?  @db.VarChar(255)
  telefono       String?  @db.VarChar(20)
  direccion      String?  @db.Text
  activo         Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relaciones
  ordenes_compra inv_ordenes_compra[]

  @@map("inv_proveedores")
}

model inv_ordenes_compra {
  id                 Int                       @id @default(autoincrement())
  proveedor_id       Int
  numero_oc          String                    @unique @db.VarChar(50)
  fecha_emision      DateTime                  @default(now())
  fecha_entrega_estimada DateTime?
  estado             String                    @default("pendiente") @db.VarChar(20)
  total              Decimal                   @default(0) @db.Decimal(10, 2)
  usuario_id         Int?
  created_at         DateTime                  @default(now())
  updated_at         DateTime                  @updatedAt

  // Relaciones
  proveedor          inv_proveedores           @relation(fields: [proveedor_id], references: [id])
  detalles           inv_detalle_orden_compra[]
  recepcion          inv_recepciones?

  @@map("inv_ordenes_compra")
}

model inv_detalle_orden_compra {
  id               Int      @id @default(autoincrement())
  orden_compra_id  Int
  producto_id      Int
  cantidad         Int
  costo_unitario   Decimal  @db.Decimal(10, 2)
  subtotal         Decimal  @db.Decimal(10, 2)

  // Relaciones
  orden_compra     inv_ordenes_compra @relation(fields: [orden_compra_id], references: [id])
  producto         cat_productos       @relation(fields: [producto_id], references: [id])

  @@map("inv_detalle_orden_compra")
}

model inv_recepciones {
  id               Int      @id @default(autoincrement())
  orden_compra_id  Int      @unique
  fecha_recepcion  DateTime @default(now())
  recibido_por     Int?
  observaciones    String?  @db.Text
  estado           String   @default("completada") @db.VarChar(20)

  // Relaciones
  orden_compra     inv_ordenes_compra @relation(fields: [orden_compra_id], references: [id])

  @@map("inv_recepciones")
}

// ==================== MÓDULO DE ÓRDENES ====================

model ord_carritos {
  id           Int               @id @default(autoincrement())
  usuario_id   Int?
  session_id   String?           @unique @db.VarChar(255)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  // Relaciones
  usuario      seg_usuarios?     @relation(fields: [usuario_id], references: [id])
  items        ord_items_carrito[]

  @@map("ord_carritos")
}

model ord_items_carrito {
  id             Int      @id @default(autoincrement())
  carrito_id     Int
  producto_id    Int
  variante_id    Int?
  cantidad       Int
  precio_unitario Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relaciones
  carrito        ord_carritos    @relation(fields: [carrito_id], references: [id])
  producto       cat_productos    @relation(fields: [producto_id], references: [id])

  @@map("ord_items_carrito")
}

model ord_cupones {
  id             Int      @id @default(autoincrement())
  codigo         String   @unique @db.VarChar(50)
  tipo           String   @db.VarChar(20)
  valor          Decimal  @db.Decimal(10, 2)
  fecha_inicio   DateTime
  fecha_fin      DateTime
  monto_minimo   Decimal? @db.Decimal(10, 2)
  usos_maximos   Int?
  usos_actuales  Int      @default(0)
  activo         Boolean  @default(true)
  created_at     DateTime @default(now())

  // Relaciones
  ordenes        ord_ordenes[]

  @@map("ord_cupones")
}

model ord_metodos_envio {
  id             Int      @id @default(autoincrement())
  nombre         String   @db.VarChar(100)
  costo          Decimal  @db.Decimal(10, 2)
  tiempo_estimado String  @db.VarChar(50)
  activo         Boolean  @default(true)
  created_at     DateTime @default(now())

  // Relaciones
  ordenes        ord_ordenes[]

  @@map("ord_metodos_envio")
}

model ord_ordenes {
  id               Int                  @id @default(autoincrement())
  cliente_id       Int
  cupon_id         Int?
  metodo_envio_id  Int?
  orden_numero     String               @unique @db.VarChar(20)
  fecha_orden      DateTime             @default(now())
  subtotal         Decimal              @db.Decimal(10, 2)
  impuesto         Decimal              @db.Decimal(10, 2)
  descuento        Decimal              @default(0) @db.Decimal(10, 2)
  costo_envio      Decimal              @default(0) @db.Decimal(10, 2)
  total            Decimal              @db.Decimal(10, 2)
  estado           String               @default("pendiente_pago") @db.VarChar(20)
  metodo_pago      String?              @db.VarChar(50)
  tracking_numero  String?              @db.VarChar(100)
  fecha_entrega    DateTime?
  created_at       DateTime             @default(now())
  updated_at       DateTime             @updatedAt
  created_by       Int?
  updated_by       Int?

  // Relaciones
  cliente          cli_clientes         @relation(fields: [cliente_id], references: [id])
  cupon            ord_cupones?         @relation(fields: [cupon_id], references: [id])
  metodo_envio     ord_metodos_envio?   @relation(fields: [metodo_envio_id], references: [id])
  items            ord_items_orden[]
  direccion_envio  ord_direcciones_envio?
  pagos            ord_pagos[]
  historial_estados ord_historial_estados[]
  resenas          cli_resenas_producto[]

  @@index([cliente_id])
  @@index([estado])
  @@index([fecha_orden])
  @@map("ord_ordenes")
}

model ord_items_orden {
  id               Int      @id @default(autoincrement())
  orden_id         Int
  producto_id      Int
  nombre_producto  String   @db.VarChar(255)
  cantidad         Int
  precio_unitario  Decimal  @db.Decimal(10, 2)
  subtotal         Decimal  @db.Decimal(10, 2)
  created_at       DateTime @default(now())

  // Relaciones
  orden            ord_ordenes    @relation(fields: [orden_id], references: [id])
  producto         cat_productos  @relation(fields: [producto_id], references: [id])

  @@map("ord_items_orden")
}

model ord_direcciones_envio {
  id                 Int      @id @default(autoincrement())
  orden_id           Int      @unique
  cliente_id         Int
  direccion_completa String   @db.Text
  ciudad             String   @db.VarChar(100)
  departamento       String   @db.VarChar(100)
  codigo_postal      String?  @db.VarChar(20)
  telefono           String   @db.VarChar(20)
  destinatario       String   @db.VarChar(200)

  // Relaciones
  orden              ord_ordenes    @relation(fields: [orden_id], references: [id])
  cliente            cli_clientes   @relation(fields: [cliente_id], references: [id])

  @@map("ord_direcciones_envio")
}

model ord_pagos {
  id               Int      @id @default(autoincrement())
  orden_id         Int
  monto            Decimal  @db.Decimal(10, 2)
  metodo           String   @db.VarChar(50)
  estado_pago      String   @default("pendiente") @db.VarChar(20)
  fecha_pago       DateTime?
  transaccion_id   String?  @db.VarChar(255)
  created_at       DateTime @default(now())

  // Relaciones
  orden            ord_ordenes @relation(fields: [orden_id], references: [id])

  @@map("ord_pagos")
}

model ord_estados_orden {
  id               Int      @id @default(autoincrement())
  nombre           String   @unique @db.VarChar(20)
  orden            Int      @default(0)
  created_at       DateTime @default(now())

  // Relaciones
  historial_estados ord_historial_estados[]

  @@map("ord_estados_orden")
}

model ord_historial_estados {
  id               Int      @id @default(autoincrement())
  orden_id         Int
  estado_anterior  String?  @db.VarChar(20)
  estado_nuevo     String   @db.VarChar(20)
  comentario       String?  @db.Text
  usuario_id       Int?
  fecha_cambio     DateTime @default(now())

  // Relaciones
  orden            ord_ordenes        @relation(fields: [orden_id], references: [id])
  usuario          seg_usuarios?      @relation(fields: [usuario_id], references: [id])
  estado_referencia ord_estados_orden @relation(fields: [estado_nuevo], references: [nombre])

  @@map("ord_historial_estados")
}

// ==================== TABLAS TRANSVERSALES ====================

model monedas {
  id                 Int      @id @default(autoincrement())
  codigo             String   @unique @db.VarChar(3)
  simbolo            String   @db.VarChar(5)
  tasa_cambio_default Decimal  @default(1) @db.Decimal(10, 4)
  created_at         DateTime @default(now())

  @@map("monedas")
}

model tipo_cambio {
  id               Int      @id @default(autoincrement())
  moneda_origen    String   @db.VarChar(3)
  moneda_destino   String   @db.VarChar(3)
  tasa             Decimal  @db.Decimal(10, 4)
  fecha            DateTime @default(now())

  @@map("tipo_cambio")
}

model configuracion_sistema {
  id               Int      @id @default(autoincrement())
  clave            String   @unique @db.VarChar(100)
  valor            String   @db.Text
  descripcion      String?  @db.Text
  updated_at       DateTime @updatedAt
  
  @@unique([id], name: "configuracion_sistema_unique_id")
  @@map("configuracion_sistema")
}

model auditoria_registro {
  id               Int      @id @default(autoincrement())
  usuario_id       Int?
  accion           String   @db.VarChar(50)
  modulo           String   @db.VarChar(50)
  tabla            String   @db.VarChar(50)
  registro_id      Int?
  datos_anteriores Json?
  datos_nuevos     Json?
  timestamp        DateTime @default(now())
  ip               String?  @db.VarChar(45)

  // Relaciones
  usuario          seg_usuarios? @relation(fields: [usuario_id], references: [id])

  @@index([timestamp])
  @@map("auditoria_registro")
}